# ===================================================
# Network Configuration
# ===================================================

# Sepolia RPC endpoint (Alchemy or Infura)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Local RPC (for Docker development)
LOCAL_RPC_URL=http://127.0.0.1:8545

# ===================================================
# Deployment
# ===================================================

# Deployer wallet private key (64-char hex string, NO 0x prefix)
# ⚠️ NEVER commit real private keys to version control!
PRIVATE_KEY=your_wallet_private_key_64_chars_hex

# ===================================================
# Chainlink Configuration (Sepolia Testnet)
# ===================================================

# LINK Token address on Sepolia
LINK_TOKEN_ADDRESS=0x779877A7B0D9E8603169DdbD7836e478b4624789

# Chainlink Oracle address (Sepolia)
ORACLE_ADDRESS=0x6090149791d654a61848D98596A87443Fae41992

# Chainlink Job ID (Any API - Get > String)
JOB_ID=ca98366cc3314ed5af205319349ad077

# LINK fee per request (in wei, 0.1 LINK = 100000000000000000)
FEE=100000000000000000

# ===================================================
# Weather API (for Chainlink External Adapter)
# ===================================================

# OpenWeatherMap API key (https://openweathermap.org/appid)
# This key is used by the Chainlink External Adapter, NOT the smart contract
OPENWEATHER_API_KEY=your_openweathermap_api_key

# ===================================================
# The Graph
# ===================================================

# The Graph Studio deploy key
GRAPH_ACCESS_TOKEN=your_graph_deploy_key

# Subgraph name (format: username/subgraph-name)
SUBGRAPH_NAME=your_username/weather-oracle

# ===================================================
# Frontend (React)
# ===================================================

# Deployed WeatherOracle contract address (update after deployment)
REACT_APP_CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Subgraph GraphQL endpoint (update after subgraph deployment)
REACT_APP_SUBGRAPH_URI=https://api.studio.thegraph.com/query/<SUBGRAPH_ID>/weather-oracle/version/latest